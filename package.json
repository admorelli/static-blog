{
  "name": "next_blog_init",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "blog": "./cli/index.ts"
  },
  "scripts": {
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:push": "drizzle-kit push",
    "dev": "next dev",
    "seed": "tsx ./scripts/seed.ts",
    "generate:static-data": "tsx ./scripts/generate-static-data.ts",
    "generate:sitemap": "next-sitemap --config next-sitemap.config.js",
    "generate:feed": "tsx ./scripts/generate-feed.ts",
    "optimize:images": "tsx ./scripts/optimize-images.ts",
    "build": "npm run generate:static-data && npm run generate:sitemap && next build && npm run generate:feed",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "mcp": "tsx ./mcp-server.ts",
    "blog": "tsx ./cli/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/react-query": "^5.100.14",
    "@types/sharp": "^0.31.1",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.5",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@tailwindcss/node": "^4.3.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.41",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2.1.9",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "inquirer": "^14.0.2",
    "jsdom": "^29.1.1",
    "next-sitemap": "^4.2.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^2.0.0"
  },
  "allowScripts": {
    "esbuild@0.18.20": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.0": true,
    "esbuild@0.21.5": true,
    "better-sqlite3@12.10.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
